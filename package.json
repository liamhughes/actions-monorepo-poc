{
  "name": "actions-monorepo-poc",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "all": "npm run format:check && npm run typecheck && npm run lint:check && npm run test && npm run build",
    "all:fix": "npm run format:fix && npm run lint:fix",
    "build": "npm run build --workspaces",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces --if-present"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/tmp": "0.2.6",
    "@types/uuid": "9.0.8",
    "@types/semver": "7.7.1",
    "tmp": "0.2.5",
    "esbuild": "0.25.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "prettier": "^3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
